# =============================================================================
# ip-list.tfvars — Shared IP Set Definitions
# =============================================================================
# Creates 4 named WAFv2 IP sets independently of any WAF Web ACL.
# Uses the ip-sets.tf resource in the root module.
#
# Usage:
#   cd waf-alb-project
#   terraform init -backend-config="key=waf-alb/ip-list.tfstate"
#   terraform plan  -var-file="environments/dev/ip-list.tfvars"
#   terraform apply -var-file="environments/dev/ip-list.tfvars"
#
# After apply, get all ARNs:
#   terraform output ip_set_arns
#
# Then reference in WAF tfvars:
#   allowlist_ip_set_arn     = "<ARN of keybank-Backend-Prod-AllowIP>"
#   allowlist_ips            = []
#   vpn_allowlist_ip_set_arn = "<ARN of site-24and7-AllowIP>"
#   vpn_allowlist_ips        = []
#   blocklist_ips            = []   # block rule uses Keybank-Orchestrator-Prod-BlockIP ARN
# =============================================================================

ip_set_region = "us-east-1"

ip_set_tags = {
  Environment = "dev"
  ManagedBy   = "Terraform"
  Purpose     = "Shared WAF IP sets"
}

